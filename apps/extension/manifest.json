{
    "manifest_version": 3,
    "name": "TeamOS Browser Extension",
    "version": "0.1.0",
    "description": "AI-powered collaborative browser extension for teams.",
    "permissions": ["storage", "tabs", "scripting", "contextMenus", "notifications"],
    "host_permissions": ["<all_urls>"],
    "background": {
        "service_worker": "./src/background/index.ts"
    },
    "action": {
        "default_popup": "./src/popup/index.html"
    },
    "content_scripts": [{
        "matches": ["<all_urls>"],
        "js": ["./src/content/index.ts"]
    }],
    "web_accessible_resources": [{
        "resources": ["src/sidepanel/*"],
        "matches": ["<all_urls>"]
    }]
}