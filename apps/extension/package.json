{
    "name": "@teamos/extension",
    "displayName": "TeamOS Browser Extension",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "manifest": {
        "permissions": ["storage", "tabs", "scripting", "contextMenus", "notifications", "sidePanel"],
        "host_permissions": ["<all_urls>"],
        "web_accessible_resources": [{
            "resources": ["sidepanel.html"],
            "matches": ["<all_urls>"]
        }]
    },
    "scripts": {
        "dev": "plasmo dev",
        "build": "plasmo build",
        "lint": "eslint . --ext .ts,.tsx"
    },
    "dependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "plasmo": "^0.90.5",
        "zustand": "^4.0.0",
        "@tanstack/react-query": "^5.0.0",
        "socket.io-client": "^4.0.0",
        "@teamos/sdk": "workspace:*",
        "@teamos/types": "workspace:*",
        "@teamos/config": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^5.6.2",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/chrome": "^0.0.268",
        "eslint": "^8.0.0",
        "eslint-plugin-react": "^7.0.0"
    }
}