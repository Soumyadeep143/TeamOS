# TeamOS Environment Configuration Template
# Copy this file to .env and configure the variables accordingly.

# FastAPI Backend Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Database & Cache Connectivity
# Defaults configured for local Docker services
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/teamos
REDIS_URL=redis://localhost:6379/0

# LLM Providers (Required for Browser Use agent, page summaries, & duplicate detection)
# Provide at least one key depending on selected model provider
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# HydraDB (Vector similarity + entity relationship graph memory)
# Leave HYDRADB_SUBTENANT_ID empty to use HydraDB's default sub-tenant.
HYDRADB_API_KEY=your_hydradb_api_key_here
HYDRADB_TENANT_ID=your_hydradb_tenant_id_here
HYDRADB_SUBTENANT_ID=

# Frontend Configuration
API_BASE_URL=http://localhost:8000
WS_BASE_URL=ws://localhost:8000
DASHBOARD_PORT=4173
